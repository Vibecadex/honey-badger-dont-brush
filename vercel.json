{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node scripts/inject-env.js",
  "outputDirectory": ".",
  "trailingSlash": false,
  "cleanUrls": false,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, must-revalidate"
        }
      ]
    },
    {
      "source": "/sdk.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    }
  ]
}
